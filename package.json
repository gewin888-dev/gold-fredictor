{
  "name": "gold-fredictor-app",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop app for validating the Gold Fredictor AI workflow.",
  "author": "gewin",
  "main": "desktop/main.js",
  "scripts": {
    "app": "electron .",
    "app:pack": "electron-builder --dir",
    "app:dist": "electron-builder"
  },
  "build": {
    "appId": "dev.gewin.gold-fredictor",
    "productName": "Gold Fredictor",
    "asar": false,
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "desktop/**/*",
      "app/**/*",
      "dashboard/**/*",
      "scripts/**/*",
      "data/**/*",
      "docs/**/*",
      "requirements.txt",
      "README.md",
      ".env.example"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "desktop/assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "40.10.2",
    "electron-builder": "^26.0.12"
  }
}
